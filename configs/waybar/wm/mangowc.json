{
  "modules-left": ["mango/workspaces", "mango/window", "mango/layout"],
  "mango/workspaces": {
    "format": "{icon}",
    "hide-empty": true,
    "on-click": "activate",
    "on-click-right": "toggle",
    "overview-label": "OVERVIEW"
  },
  "mango/window": {
    "format": "{}",
    "icon-size": 20
  },
  "mango/layout": {
    "format": "{symbol}",
    "format-T": "Tile",
    "format-S": "Scroller",
    "format-G": "Grid",
    "format-M": "Monocle",
    "format-K": "Deck",
    "format-CT": "Center Tile",
    "format-RT": "Right Tile",
    "format-VS": "Vertical Scroller",
    "format-VT": "Vertical Tile",
    "format-VG": "Vertical Grid",
    "format-VK": "Vertical Deck",
    "format-DW": "Dwindle",
    "format-F": "Fair",
    "format-VF": "Vertical Fair"
  }
}
